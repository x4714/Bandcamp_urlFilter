# Important: so Python recognizes local directories (for example `logic`) as modules.
PYTHONPATH=.

# Optional: if omitted, the app auto-discovers the Qobuz App ID from the web player.
# QOBUZ_APP_ID=

# Required for live Qobuz matching and streamrip auth-token workflows.
QOBUZ_USER_AUTH_TOKEN=

# Optional app login for public-facing deployments.
APP_AUTH_ENABLED=0
APP_AUTH_USERNAME=
APP_AUTH_PASSWORD_HASH=
# Optional auth hardening for public-facing deployments.
APP_AUTH_SESSION_TTL_SECONDS=43200
APP_AUTH_MAX_FAILURES=5
APP_AUTH_LOCKOUT_SECONDS=900

# Optional: tracker credentials for duplicate checking / upload helpers.
RED_API_KEY=
RED_SESSION_COOKIE=
# RED_URL=https://redacted.sh
OPS_API_KEY=
OPS_SESSION_COOKIE=
# OPS_URL=https://orpheus.network
